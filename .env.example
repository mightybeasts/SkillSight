# ─── Supabase (cloud) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── PostgreSQL (local Docker) ──────────────────────────────────────────────
POSTGRES_USER=skillsight
POSTGRES_PASSWORD=skillsight_dev_password
POSTGRES_DB=skillsight
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://skillsight:skillsight_dev_password@postgres:5432/skillsight

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── FastAPI ────────────────────────────────────────────────────────────────
API_SECRET_KEY=change-this-to-a-random-secret-key-in-production
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:8081

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI / NLP Models ────────────────────────────────────────────────────────
# HuggingFace model for embeddings (downloaded on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
# Optional: fallback to Gemini API for complex analysis
GEMINI_API_KEY=your-gemini-api-key-optional

# ─── Next.js (web) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# ─── Expo (mobile) ──────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:8000

# ─── Docker / CI ────────────────────────────────────────────────────────────
GHCR_REGISTRY=ghcr.io
GHCR_IMAGE_PREFIX=ghcr.io/your-github-username/skillsight
